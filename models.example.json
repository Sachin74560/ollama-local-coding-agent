{
  "//": "Copy to models.json and set QWEN_HARNESS_MODEL_SOURCE=file to use your own models + connections.",
  "//connections": "OPTIONAL named API/account blocks. A model picks one via its 'connection' field. Define the SAME api type under several names (with different apiKeyEnv) to use multiple accounts. Names must be unique — a duplicate resolves to the LAST. A model with no 'connection' uses 'local'.",
  "connections": {
    "local": { "type": "ollama", "baseUrl": "http://127.0.0.1:11434" },
    "remote-ollama": { "type": "compat", "baseUrl": "https://api.example.com/v1", "apiKeyEnv": "GROQ_API_KEY" }
  },
  "//compat": "External /v1 (compat) providers land in the next release. Shape (for when ready): \"groq-work\": { \"type\": \"compat\", \"baseUrl\": \"https://api.example.com/v1\", \"apiKeyEnv\": \"GROQ_WORK\" } — the key itself goes in .env, only the env-var NAME goes here.",
  "models": {
    "your-model:tag": {
      "name": "your-model:tag",
      "role": "general",
      "numCtx": 8192,
      "keepAlive": "5m",
      "sampling": { "temperature": 0.1, "top_p": 0.9, "top_k": 20, "repeat_penalty": 1.1 },
      "approxSizeGB": 5,
      "connection": "remote-ollama"
    },
    "qwen3:0.6b": {
      "name": "qwen3:0.6b",
      "role": "worker",
      "numCtx": 8192,
      "keepAlive": "5m",
      "sampling": { "temperature": 0.1, "top_p": 0.9, "top_k": 20, "repeat_penalty": 1.05 },
      "approxSizeGB": 1
    },
    "qwen2.5:3b-instruct": {
      "name": "qwen2.5:3b-instruct",
      "role": "worker",
      "numCtx": 8192,
      "keepAlive": "5m",
      "sampling": { "temperature": 0.1, "top_p": 0.9, "top_k": 20, "repeat_penalty": 1.05 },
      "approxSizeGB": 2.0
    },
    "qwen2.5:7b-instruct": {
      "name": "qwen2.5:7b-instruct",
      "role": "worker",
      "numCtx": 8192,
      "keepAlive": "5m",
      "sampling": { "temperature": 0.1, "top_p": 0.9, "top_k": 20, "repeat_penalty": 1.05 },
      "approxSizeGB": 4.7
